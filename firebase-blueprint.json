{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth UID of the user." },
        "displayName": { "type": "string", "description": "The user's display name from Google Auth." },
        "email": { "type": "string", "description": "The user's email address." },
        "photoURL": { "type": "string", "description": "The user's profile photo URL." },
        "bio": { "type": "string", "description": "A short bio about the user." },
        "notificationSettings": {
          "type": "object",
          "properties": {
            "enableSounds": { "type": "boolean" },
            "notifyNewPosts": { "type": "boolean" },
            "notifyNewMessages": { "type": "boolean" },
            "messageSound": { "type": "string" },
            "postSound": { "type": "string" }
          }
        },
        "customTheme": {
          "type": "object",
          "properties": {
            "wallpaper": { "type": "string" },
            "pattern": { "type": "string" },
            "primaryColor": { "type": "string" },
            "secondaryColor": { "type": "string" },
            "accentColor": { "type": "string" },
            "textColor": { "type": "string" },
            "cardBgColor": { "type": "string" },
            "sidebarBgColor": { "type": "string" },
            "headerBgColor": { "type": "string" },
            "bodyBgColor": { "type": "string" },
            "glassEffect": { "type": "boolean" },
            "blurAmount": { "type": "number" },
            "opacity": { "type": "number" },
            "wallpaperX": { "type": "number" },
            "wallpaperY": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the profile was last updated." }
      },
      "required": ["uid", "displayName", "email", "createdAt"]
    },
    "Report": {
      "title": "Report",
      "description": "A user report against another user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reporterUid": { "type": "string" },
        "reportedUid": { "type": "string" },
        "reason": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "resolved"] }
      },
      "required": ["reporterUid", "reportedUid", "reason", "createdAt", "status"]
    },
    "Post": {
      "title": "Post",
      "description": "A message posted by a user to the public feed.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorUid", "authorName", "content", "createdAt"]
    },
    "Whitelist": {
      "title": "Whitelisted Email",
      "description": "An email address allowed to access the forum.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" },
        "addedBy": { "type": "string" }
      },
      "required": ["email", "addedAt"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A private chat between two users.",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "participantNames": { "type": "object" },
        "lastMessage": { "type": "string" },
        "lastMessageSenderUid": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants", "updatedAt"]
    },
    "DirectMessage": {
      "title": "Direct Message",
      "description": "A single message within a conversation.",
      "type": "object",
      "properties": {
        "senderUid": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderUid", "text", "createdAt"]
    },
    "TypingStatus": {
      "title": "Typing Status",
      "description": "Indicates if a user is currently typing in a conversation.",
      "type": "object",
      "properties": {
        "conversationId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "isTyping": { "type": "boolean" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["conversationId", "userId", "userName", "isTyping", "lastUpdated"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "status": { "type": "string" }
      },
      "required": ["status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles, keyed by their Auth UID."
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Public feed of messages."
    },
    "/whitelist/{email}": {
      "schema": "Whitelist",
      "description": "List of emails allowed to access the app."
    },
    "/conversations/{convId}": {
      "schema": "Conversation",
      "description": "Private chat metadata."
    },
    "/conversations/{convId}/messages/{msgId}": {
      "schema": "DirectMessage",
      "description": "Messages within a private chat."
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "User-submitted reports."
    },
    "/typing/{typingId}": {
      "schema": "TypingStatus",
      "description": "Real-time typing indicators."
    },
    "/settings/{settingId}": {
      "schema": "Setting",
      "description": "Global application settings."
    }
  }
}
